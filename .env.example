# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# ─── Database (PostgreSQL 16 / Supabase) ─────────────────────────────────────
# Async SQLAlchemy URL. For Supabase use the pooled connection string.
DATABASE_URL=postgresql+asyncpg://pulse:pulse@postgres:5432/pulse

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Supabase Auth ───────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret          # used to verify access tokens server-side

# ─── Secrets at rest ─────────────────────────────────────────────────────────
# 32-byte urlsafe-base64 key used to Fernet-encrypt OAuth tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── Token Router (ALL LLM / "AAM" model calls route through this gateway) ───
# Protocol: "openai" => POST {base}/chat/completions, "anthropic" => {base}/messages
TOKEN_ROUTER_API_KEY=
TOKEN_ROUTER_BASE_URL=          # e.g. https://api.tokenrouter.io/v1
TOKEN_ROUTER_MODEL=claude-sonnet-4-6
TOKEN_ROUTER_PROTOCOL=openai

# Direct Anthropic — used only as a fallback when Token Router is not configured.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Convex (auth backend — multi-tenant: each business is a tenant) ─────────
CONVEX_URL=                     # deployment URL, e.g. https://your-app.convex.cloud
CONVEX_API_KEY=                 # shared secret authorizing API -> Convex calls
# Backend signs a session token after Convex verifies the login.
AUTH_JWT_SECRET=change-me-in-production
AUTH_JWT_TTL_HOURS=168

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Square OAuth ────────────────────────────────────────────────────────────
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENVIRONMENT=sandbox          # sandbox | production

# ─── Stripe (Pulse billing + Stripe data adapter) ────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_xxx

# ─── Frontend ────────────────────────────────────────────────────────────────
# Consumed by Vite at build time (must be prefixed with VITE_).
VITE_API_BASE_URL=http://localhost:8000
VITE_CONVEX_URL=                # https://your-app.convex.cloud (if frontend talks to Convex directly)
