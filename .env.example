# ─── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO

# Runtime URL may use the Supabase transaction pooler (port 6543). Alembic
# requires the direct database URL (port 5432) when migrations are deployed.
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse
DATABASE_MIGRATION_URL=
DB_USE_PGBOUNCER=false
DB_SSL=



# ─── Supabase Auth ───────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret          # used to verify access tokens server-side

# ─── Secrets at rest ─────────────────────────────────────────────────────────
# 32-byte urlsafe-base64 key used to Fernet-encrypt OAuth tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── Token Router (ALL LLM / "AAM" model calls route through this gateway) ───
# Protocol: "openai" => POST {base}/chat/completions, "anthropic" => {base}/messages
TOKEN_ROUTER_API_KEY=
TOKEN_ROUTER_BASE_URL=          # e.g. https://api.tokenrouter.io/v1
TOKEN_ROUTER_MODEL=claude-sonnet-4-6
TOKEN_ROUTER_PROTOCOL=openai



# ─── Competitor price research ───────────────────────────────────────────────
# Server-only. Used by POST /api/competitor-prices/research.
# Perplexity supplies grounded competitor/menu search evidence. DeepSeek turns
# that evidence into structured competitors and strict price observations.
# Google Maps is used only for deterministic address geocoding and radius checks.
GOOGLE_MAPS_SERVER_API_KEY=
# Legacy fallback for existing deployments:
GOOGLE_MAPS_API_KEY=
ENABLE_GOOGLE_PLACES_DISCOVERY=true
ENABLE_DIRECT_SOURCE_FETCH=true
THIRD_PARTY_FRESHNESS_MONTHS=18
COMPETITOR_RESEARCH_DEADLINE_SECONDS=60
STRICT_FREE_TIER=true

PERPLEXITY_API_KEY=
PERPLEXITY_SEARCH_BASE_URL=https://api.perplexity.ai
ENABLE_PERPLEXITY_SEARCH=true
PERPLEXITY_SEARCH_COUNTRY=US
PERPLEXITY_SEARCH_CONTEXT_SIZE=high
PERPLEXITY_MAX_RESULTS=5
PERPLEXITY_MAX_QUERIES_PER_COMPETITOR=3
PERPLEXITY_MAX_TOKENS_PER_PAGE=2048

# TokenMart gateway. The API key remains server-side.
TOKENMART_API_KEY=
TOKENMART_BASE_URL=https://model.service-inference.ai/v1
TOKENMART_MODEL=deepseek-v4-flash
ENABLE_DEEPSEEK_EXTRACTION=true

# ─── Supabase (Postgres database + Auth) ─────────────────────────────────────
# The backend verifies Supabase access tokens. SUPABASE_URL alone suffices (JWKS);
# set SUPABASE_JWT_SECRET only for legacy HS256 projects.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Extra CORS origins (comma-separated) — add your Vercel domain in production.
EXTRA_CORS_ORIGINS=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── SMS (Twilio) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Square OAuth ("Connect with Square" button) ─────────────────────────────
# developer.squareup.com → your app → OAuth. Register the redirect URL:
#   {API_BASE_URL}/api/integrations/oauth/square/callback
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENVIRONMENT=sandbox          # sandbox | production

# ─── Stripe (Connect OAuth button + Pulse billing) ───────────────────────────
# dashboard.stripe.com → Settings → Connect → OAuth. Client ID = ca_… Register:
#   {API_BASE_URL}/api/integrations/oauth/stripe/callback
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Public URL of this backend — used to build the OAuth redirect URLs above.
API_BASE_URL=http://localhost:8000

# ─── Frontend ────────────────────────────────────────────────────────────────
# Consumed by Vite at build time (must be prefixed with VITE_). These are PUBLIC —
# never put service-role keys or other secrets here (they ship in the JS bundle).
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=              # https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=        # Supabase anon/public key
